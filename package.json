{
  "name": "lean4-compiler",
  "version": "1.0.0",
  "description": "A Lean4 compiler implemented in TypeScript",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "lean4-compiler": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "start": "node --stack-size=4096 node_modules/ts-node/dist/bin.js src/index.ts",
    "compile": "node --stack-size=4096 node_modules/ts-node/dist/bin.js src/index.ts",
    "lint": "eslint src/**/*.ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "lean4",
    "compiler",
    "theorem-prover",
    "dependent-types"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
